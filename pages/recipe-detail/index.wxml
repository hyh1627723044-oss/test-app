<view class="page-shell">
  <view class="detail-card paper-card">
    <image class="card-tape" src="/assets/illustrations/tape-green.png" mode="aspectFit" />
    <image class="card-decor" src="/assets/illustrations/decor-leaf.png" mode="aspectFit" />
    <view class="detail-main">
      <view class="cover-section">
        <swiper
          wx:if="{{recipe.cover_images.length > 0}}"
          class="cover-swiper"
          indicator-dots
          circular
        >
          <swiper-item wx:for="{{recipe.cover_images}}" wx:key="file_id">
            <image class="cover-image" src="{{item.file_id}}" mode="aspectFill" />
          </swiper-item>
        </swiper>
        <image
          wx:elif="{{recipe.primary_cover_file_id}}"
          class="cover-image"
          src="{{recipe.primary_cover_file_id}}"
          mode="aspectFill"
        />
        <view wx:else class="cover-empty">
          <text class="cover-empty-text">{{coverLetter}}</text>
        </view>
      </view>
      <view class="detail-copy">
    <view class="title-row">
      <text class="recipe-title">{{recipe.title}}</text>
      <view class="favorite-btn" bind:tap="onFavorite">
        <text class="favorite-text">{{isFavorited ? '已收藏' : '收藏'}}</text>
      </view>
    </view>
    <view class="owner-actions" wx:if="{{canEdit}}">
      <view class="owner-action-btn" bind:tap="onEditRecipe">
        <text class="owner-action-text">编辑菜谱</text>
      </view>
      <view class="owner-action-btn owner-action-danger" bind:tap="onDeleteRecipe">
        <text class="owner-action-text owner-action-danger-text">删除</text>
      </view>
    </view>
    <text class="recipe-desc">{{recipe.description}}</text>
    <view class="meta-row">
      <text class="meta-pill">{{recipe.cook_time_minutes}} 分钟</text>
      <text class="meta-pill">{{difficultyMap[recipe.difficulty] || recipe.difficulty}}</text>
      <text class="meta-pill">{{recipe.servings}} 人份</text>
      <text class="meta-pill" wx:if="{{recipe.calories}}">{{recipe.calories}} kcal</text>
    </view>
    <view class="tag-row" wx:if="{{recipe.tags.length > 0}}">
      <text class="tag-pill" wx:for="{{recipe.tags}}" wx:key="*this">#{{item}}</text>
    </view>
      </view>
    </view>
  </view>

  <view class="section paper-card">
    <text class="section-title">加入计划</text>
    <picker mode="date" value="{{selectedDate}}" bind:change="onChangeDate">
      <view class="date-picker">
        <text class="date-label">日期</text>
        <text class="date-value">{{selectedDate}}</text>
      </view>
    </picker>
    <view class="slot-row">
      <view
        class="slot-pill {{selectedSlot === item.id ? 'slot-pill-active' : ''}}"
        wx:for="{{mealSlots}}"
        wx:key="id"
        data-slot="{{item.id}}"
        bind:tap="onChooseSlot"
      >
        <text class="slot-text">{{item.name}}</text>
      </view>
    </view>
    <view class="add-plan-btn" bind:tap="onAddToPlan">
      <text class="add-plan-text">加入这一天</text>
    </view>
  </view>

  <view class="section paper-card">
    <text class="section-title">食材</text>
    <block wx:if="{{recipe.ingredients.length > 0}}">
      <view class="ingredient-item" wx:for="{{recipe.ingredients}}" wx:key="name">
        <text class="ingredient-name">{{item.name}}</text>
        <text class="ingredient-amount">{{item.amount}}</text>
      </view>
    </block>
    <text wx:else class="section-empty">还没有填写食材</text>
  </view>

  <view class="section paper-card">
    <text class="section-title">做法</text>
    <block wx:if="{{recipe.steps.length > 0}}">
      <view class="step-item" wx:for="{{recipe.steps}}" wx:key="order">
        <text class="step-index">{{item.order}}</text>
        <text class="step-text">{{item.text}}</text>
      </view>
    </block>
    <text wx:else class="section-empty">还没有填写做法</text>
  </view>
</view>
