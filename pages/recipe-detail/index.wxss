.page-shell {
  min-height: 100vh;
  padding: 28rpx 28rpx 190rpx;
  box-sizing: border-box;
}

.detail-card {
  position: relative;
  padding: 22rpx;
  overflow: hidden;
}

.card-tape {
  position: absolute;
  left: 34rpx;
  top: -24rpx;
  width: 150rpx;
  height: 66rpx;
  transform: rotate(-4deg);
  z-index: 2;
}

.card-decor {
  position: absolute;
  right: 20rpx;
  top: 18rpx;
  width: 78rpx;
  height: 78rpx;
  z-index: 2;
}

.detail-main {
  display: flex;
  flex-direction: row;
  align-items: stretch;
}

.cover-section {
  width: 236rpx;
  height: 236rpx;
  border-radius: 24rpx;
  overflow: hidden;
  background-color: #f0c993;
  border: 1px solid #d7b17e;
  flex-shrink: 0;
}

.cover-swiper,
.cover-image,
.cover-empty {
  width: 236rpx;
  height: 236rpx;
}

.cover-empty {
  background-color: #f0c993;
  display: flex;
  justify-content: center;
  align-items: center;
}

.cover-empty-text {
  width: 146rpx;
  height: 146rpx;
  border-radius: 76rpx;
  background-color: #fff6df;
  border: 5rpx solid #4b321f;
  box-shadow: 7rpx 7rpx 0 rgba(196, 105, 31, 0.25);
  text-align: center;
  line-height: 146rpx;
  font-size: 72rpx;
  color: #8a4f1c;
  font-weight: 600;
}

.detail-copy {
  flex: 1;
  min-width: 0;
  padding-left: 22rpx;
  padding-right: 54rpx;
  box-sizing: border-box;
}

.section {
  margin-top: 22rpx;
  padding: 26rpx;
  box-sizing: border-box;
}

.recipe-title {
  flex: 1;
  font-size: 38rpx;
  line-height: 46rpx;
  color: #251b14;
  font-weight: 600;
  word-break: break-all;
}

.title-row {
  display: flex;
  flex-direction: row;
  align-items: center;
}

.favorite-btn {
  min-width: 96rpx;
  height: 50rpx;
  padding: 0 16rpx;
  border-radius: 20rpx;
  background-color: #fff6df;
  border: 2rpx solid #cfa46f;
  display: flex;
  justify-content: center;
  align-items: center;
  flex-shrink: 0;
}

.favorite-text {
  font-size: 24rpx;
  color: #8a5a34;
}

.owner-actions {
  margin-top: 16rpx;
  display: flex;
  flex-direction: row;
}

.owner-action-btn {
  height: 54rpx;
  margin-right: 14rpx;
  padding: 0 20rpx;
  border-radius: 18rpx;
  background-color: #fff6ec;
  border: 2rpx solid #e1c6a9;
  display: flex;
  align-items: center;
  justify-content: center;
}

.owner-action-danger {
  background-color: #fff1ee;
  border-color: #f0b8a5;
}

.owner-action-text {
  font-size: 24rpx;
  color: #a2672a;
}

.owner-action-danger-text {
  color: #b45135;
}

.recipe-desc {
  display: block;
  margin-top: 16rpx;
  font-size: 25rpx;
  line-height: 36rpx;
  color: #74675d;
}

.meta-row,
.slot-row {
  margin-top: 20rpx;
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
}

.meta-pill,
.slot-pill {
  margin-right: 14rpx;
  margin-bottom: 14rpx;
  padding: 10rpx 18rpx;
  border-radius: 18rpx;
  background-color: #fff0da;
  font-size: 24rpx;
  color: #8a5a34;
}

.slot-pill {
  background-color: #f6eee6;
}

.slot-pill-active {
  background-color: #4b321f;
}

.slot-text {
  font-size: 24rpx;
  color: #8a5a34;
}

.slot-pill-active .slot-text {
  color: #fff8ef;
}

.tag-row {
  margin-top: 18rpx;
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
}

.tag-pill {
  margin: 0 12rpx 12rpx 0;
  padding: 8rpx 14rpx;
  border-radius: 16rpx;
  background-color: #ffe2b5;
  font-size: 22rpx;
  color: #a2672a;
}

.date-picker {
  height: 74rpx;
  padding: 0 20rpx;
  border-radius: 18rpx;
  background-color: #fff6df;
  border: 2rpx dashed #cfa46f;
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
}

.date-label,
.date-value {
  font-size: 26rpx;
  color: #4d4036;
}

.add-plan-btn {
  height: 76rpx;
  margin-top: 10rpx;
  border-radius: 24rpx;
  background-color: #ee8e36;
  border: 4rpx solid #4b321f;
  display: flex;
  justify-content: center;
  align-items: center;
}

.add-plan-text {
  font-size: 28rpx;
  color: #fff8ef;
  font-weight: 600;
}

.section-title {
  display: block;
  margin-bottom: 18rpx;
  font-size: 32rpx;
  color: #251b14;
  font-weight: 600;
}

.section-empty {
  display: block;
  padding: 18rpx 0;
  font-size: 26rpx;
  color: #9e8068;
}

.ingredient-item {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  padding: 16rpx 0;
  border-bottom: 1px solid #f0e7df;
}

.ingredient-name,
.ingredient-amount {
  font-size: 28rpx;
  color: #4d4036;
}

.step-item {
  display: flex;
  flex-direction: row;
  margin-bottom: 20rpx;
}

.step-index {
  width: 42rpx;
  height: 42rpx;
  margin-right: 16rpx;
  border-radius: 21rpx;
  background-color: #ee8e36;
  color: #fff8ef;
  font-size: 24rpx;
  line-height: 42rpx;
  text-align: center;
  flex-shrink: 0;
}

.step-text {
  flex: 1;
  font-size: 28rpx;
  line-height: 42rpx;
  color: #4d4036;
}
