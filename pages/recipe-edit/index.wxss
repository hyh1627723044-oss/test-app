.page-shell {
  min-height: 100vh;
  padding: 24rpx;
  box-sizing: border-box;
  background-color: #fbfaf7;
}

.image-uploader {
  min-height: 280rpx;
  border-radius: 28rpx;
  background-color: #eee0d7;
  display: flex;
  align-items: center;
}

.uploader-empty {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.uploader-image {
  width: 138rpx;
  height: 138rpx;
  margin-bottom: 8rpx;
}

.uploader-title {
  font-size: 34rpx;
  color: #251b14;
  font-weight: 600;
}

.uploader-desc {
  margin-top: 12rpx;
  font-size: 26rpx;
  color: #796556;
}

.image-list {
  white-space: nowrap;
  padding: 20rpx;
  box-sizing: border-box;
}

.preview-image {
  width: 220rpx;
  height: 220rpx;
  margin-right: 18rpx;
  border-radius: 22rpx;
}

.ai-recognize-btn {
  min-height: 118rpx;
  margin-top: 20rpx;
  padding: 14rpx 22rpx;
  box-sizing: border-box;
  border-radius: 26rpx;
  background-color: #ffe2b5;
  border: 3rpx solid #6f5137;
  box-shadow: 5rpx 6rpx 0 rgba(112, 70, 38, 0.18);
  display: flex;
  align-items: center;
}

.ai-recognize-btn-disabled {
  opacity: 0.62;
}

.ai-recognize-icon {
  width: 90rpx;
  height: 90rpx;
  flex-shrink: 0;
}

.ai-recognize-copy {
  flex: 1;
  padding-left: 18rpx;
}

.ai-recognize-title,
.ai-recognize-desc {
  display: block;
}

.ai-recognize-title {
  font-size: 30rpx;
  color: #3b2718;
  font-weight: 600;
}

.ai-recognize-desc {
  margin-top: 6rpx;
  font-size: 22rpx;
  line-height: 32rpx;
  color: #72543d;
}

.form-card {
  margin-top: 24rpx;
  padding: 26rpx;
  box-sizing: border-box;
  background-color: #ffffff;
  border: 1px solid #eee5dc;
  border-radius: 24rpx;
}

.field-label {
  display: block;
  margin: 22rpx 0 12rpx;
  font-size: 28rpx;
  color: #251b14;
  font-weight: 600;
}

.field-label:first-child {
  margin-top: 0;
}

.field-input,
.field-textarea {
  width: 100%;
  padding: 18rpx;
  box-sizing: border-box;
  border-radius: 18rpx;
  background-color: #f8f3ee;
  font-size: 28rpx;
  color: #251b14;
}

.field-input {
  height: 78rpx;
}

.field-textarea {
  height: 168rpx;
}

.field-textarea-tall {
  height: 220rpx;
}

.two-column {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
}

.column-field {
  width: 304rpx;
}

.picker-field {
  height: 78rpx;
  padding: 18rpx;
  box-sizing: border-box;
  border-radius: 18rpx;
  background-color: #f8f3ee;
  font-size: 28rpx;
  color: #251b14;
}

.pill-row {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
}

.choice-pill {
  margin: 0 14rpx 14rpx 0;
  padding: 12rpx 20rpx;
  border-radius: 18rpx;
  background-color: #f8f3ee;
  border: 1px solid #eee5dc;
}

.choice-pill-active {
  background-color: #2b2119;
  border-color: #2b2119;
}

.choice-text {
  font-size: 26rpx;
  color: #6f6258;
}

.choice-pill-active .choice-text {
  color: #fff8ef;
}

.selected-tags {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
}

.selected-tag {
  margin: 0 14rpx 14rpx 0;
  padding: 12rpx 18rpx;
  border-radius: 18rpx;
  background-color: #2b2119;
  display: flex;
  flex-direction: row;
  align-items: center;
}

.selected-tag-text,
.selected-tag-remove {
  font-size: 26rpx;
  color: #fff8ef;
}

.selected-tag-remove {
  margin-left: 10rpx;
}

.hint-text {
  display: block;
  font-size: 26rpx;
  color: #8f8177;
}

.field-title-row {
  margin-top: 22rpx;
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
}

.field-label-inline {
  margin: 0 0 12rpx;
}

.more-tags {
  padding: 8rpx 16rpx;
  border-radius: 16rpx;
  background-color: #f6eee6;
}

.more-tags-text {
  font-size: 24rpx;
  color: #8a5a34;
}

.custom-tag-row {
  display: flex;
  flex-direction: row;
  align-items: center;
}

.custom-tag-input {
  flex: 1;
  height: 78rpx;
  padding: 18rpx;
  box-sizing: border-box;
  border-radius: 18rpx;
  background-color: #f8f3ee;
  font-size: 28rpx;
  color: #251b14;
}

.custom-tag-btn {
  width: 120rpx;
  height: 78rpx;
  margin-left: 14rpx;
  border-radius: 22rpx;
  background-color: #c87420;
  border: 4rpx solid #2b2119;
  box-sizing: border-box;
  display: flex;
  justify-content: center;
  align-items: center;
}

.custom-tag-btn-text {
  font-size: 26rpx;
  color: #fff8ef;
}

.switch-row {
  margin-top: 24rpx;
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
}

.switch-copy {
  display: flex;
  flex-direction: column;
}

.switch-title {
  font-size: 28rpx;
  color: #251b14;
  font-weight: 600;
}

.switch-desc {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #8f8177;
}

.submit-btn {
  height: 86rpx;
  margin-top: 28rpx;
  border-radius: 28rpx;
  background-color: #c87420;
  border: 4rpx solid #2b2119;
  display: flex;
  justify-content: center;
  align-items: center;
}

.submit-text {
  font-size: 30rpx;
  color: #fff8ef;
  font-weight: 600;
}
