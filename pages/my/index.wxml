<view class="page-shell">
  <view class="profile-card">
    <view class="avatar">
      <text class="avatar-text">我</text>
    </view>
    <view class="profile-copy">
      <text class="profile-name">体验用户</text>
      <text class="profile-desc">管理自己的菜谱、收藏和饮食计划</text>
    </view>
  </view>

  <view class="stats">
    <view class="stat-item" wx:for="{{stats}}" wx:key="label">
      <text class="stat-value">{{item.value}}</text>
      <text class="stat-label">{{item.label}}</text>
    </view>
  </view>

  <view class="menu-card">
    <text class="menu-title">下一步功能</text>
    <text class="menu-line">云开发登录与 openid</text>
    <text class="menu-line">上传菜品封面图列表</text>
    <text class="menu-line">AI 推荐菜品和饮品</text>
  </view>

  <view class="bottom-nav">
    <view class="nav-item" bind:tap="onTapMenu">
      <text class="nav-symbol">菜</text>
      <text class="nav-label">菜单</text>
    </view>
    <view class="nav-item" bind:tap="onTapPlan">
      <text class="nav-symbol">计</text>
      <text class="nav-label">计划</text>
    </view>
    <view class="nav-item nav-item-active">
      <text class="nav-symbol">我</text>
      <text class="nav-label">我的</text>
    </view>
  </view>
</view>
