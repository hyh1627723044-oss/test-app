<view class="page-shell">
  <view class="profile-card paper-card paper-hero">
    <image class="profile-tape" src="/assets/illustrations/tape-pink.png" mode="aspectFit" />
    <view class="avatar">
      <text class="avatar-text">我</text>
    </view>
    <view class="profile-copy">
      <text class="eyebrow">我的厨房</text>
      <text class="profile-name">体验用户</text>
      <text class="profile-desc">管理我的菜谱和饮食计划</text>
    </view>
    <view class="profile-heart"></view>
  </view>

  <view class="stats paper-card">
    <view class="stat-item" wx:for="{{stats}}" wx:key="label">
      <text class="stat-value">{{item.value}}</text>
      <text class="stat-label">{{item.label}}</text>
    </view>
  </view>

  <view class="feature-card paper-card my-recipes-card">
    <image class="feature-tape" src="/assets/illustrations/tape-yellow.png" mode="aspectFit" />
    <image class="my-recipes-image" src="/assets/illustrations/my-recipes-pot.png" mode="aspectFit" />
    <view class="feature-copy">
      <text class="feature-title">我的菜谱</text>
      <text class="feature-desc">整理自己上传的菜品、封面和标签。</text>
    </view>
    <text class="feature-arrow">›</text>
  </view>

  <view class="feature-card paper-card plan-entry-card" bind:tap="onTapPlan">
    <image class="feature-tape" src="/assets/illustrations/tape-green.png" mode="aspectFit" />
    <image class="feature-image" src="/assets/illustrations/empty-plan.png" mode="aspectFit" />
    <view class="feature-copy">
      <text class="feature-title">饮食计划</text>
      <text class="feature-desc">查看今天的早中晚安排。</text>
    </view>
    <text class="feature-arrow">›</text>
  </view>

  <view class="feature-card paper-card ai-card">
    <image class="feature-tape" src="/assets/illustrations/tape-pink.png" mode="aspectFit" />
    <image class="ai-image" src="/assets/illustrations/ai-chef.png" mode="aspectFit" />
    <view class="feature-copy">
      <text class="feature-title">AI 推荐</text>
      <text class="feature-desc">根据口味和库存推荐菜品。</text>
    </view>
    <text class="feature-arrow">›</text>
  </view>

  <view class="menu-card paper-card">
    <image class="menu-tape" src="/assets/illustrations/tape-green.png" mode="aspectFit" />
    <text class="menu-title">下一步功能</text>
    <view class="menu-line">
      <view class="menu-dot"></view>
      <text class="menu-line-text">云开发登录与 openid</text>
    </view>
    <view class="menu-line">
      <view class="menu-dot"></view>
      <text class="menu-line-text">上传菜品封面图列表</text>
    </view>
    <view class="menu-line">
      <view class="menu-dot"></view>
      <text class="menu-line-text">AI 推荐菜品和饮品</text>
    </view>
  </view>

  <view class="draw-card paper-card">
    <image class="draw-tape" src="/assets/illustrations/tape-yellow.png" mode="aspectFit" />
    <view class="draw-head">
      <view class="draw-copy">
        <text class="draw-eyebrow">选择困难救星</text>
        <text class="draw-title">今天随机吃什么？</text>
        <text class="draw-desc">从我的菜谱里抽一道，可以先按标签缩小池子。</text>
      </view>
      <view class="draw-badge">
        <text class="draw-badge-text">{{drawPool.length}} 道</text>
      </view>
    </view>

    <view class="draw-mode-row">
      <view
        class="draw-mode {{activeDrawMode === item.id ? 'draw-mode-active' : ''}}"
        wx:for="{{drawModes}}"
        wx:key="id"
        data-mode="{{item.id}}"
        bind:tap="onChangeDrawMode"
      >
        <text class="draw-mode-text">{{item.name}}</text>
      </view>
    </view>

    <scroll-view class="draw-tag-scroll" scroll-x>
      <view class="draw-tag-row">
        <view
          class="draw-tag {{activeDrawTag === item ? 'draw-tag-active' : ''}}"
          wx:for="{{drawTags}}"
          wx:key="*this"
          data-tag="{{item}}"
          bind:tap="onSelectDrawTag"
        >
          <text class="draw-tag-text">{{item}}</text>
        </view>
      </view>
    </scroll-view>

    <view class="draw-stage">
      <view wx:if="{{activeDrawMode === 'wheel'}}" class="wheel-wrap">
        <image class="wheel-pointer-image" src="/assets/illustrations/random-wheel-pointer.png" mode="aspectFit" />
        <image class="wheel-image" src="/assets/illustrations/random-wheel.png" mode="aspectFit" style="{{wheelStyle}}" />
      </view>

      <view wx:if="{{activeDrawMode === 'gacha'}}" class="gacha-wrap {{gachaOpen ? 'gacha-open' : ''}}">
        <image class="gacha-machine-image" src="/assets/illustrations/gacha-machine.png" mode="aspectFit" />
        <image class="gacha-capsule-image" src="/assets/illustrations/gacha-capsule.png" mode="aspectFit" />
      </view>
    </view>

    <view class="draw-button" bind:tap="onStartDraw">
      <text class="draw-button-text">{{isDrawing ? '抽取中...' : '开始抽菜'}}</text>
    </view>

    <view class="draw-result" wx:if="{{drawResult}}">
      <text class="draw-result-label">抽到了</text>
      <text class="draw-result-title">{{drawResult.title}}</text>
      <text class="draw-result-desc">{{drawResult.description || '这道菜今天很有缘。'}}</text>
      <view class="draw-result-tags" wx:if="{{drawResult.tags.length > 0}}">
        <text class="draw-result-tag" wx:for="{{drawResult.tags}}" wx:key="*this">#{{item}}</text>
      </view>
      <view class="draw-action-row">
        <view class="draw-action-btn" bind:tap="onViewDrawRecipe">
          <text class="draw-action-text">查看详情</text>
        </view>
        <view class="draw-action-btn draw-action-primary" bind:tap="onAddDrawToPlan">
          <text class="draw-action-primary-text">加入今日</text>
        </view>
      </view>
    </view>
  </view>

  <view class="bottom-nav">
    <view class="nav-item" data-id="recipes" bind:tap="onTapTab">
      <image class="nav-icon" src="/assets/illustrations/tab-recipes.png" mode="aspectFit" />
      <text class="nav-label">菜单</text>
    </view>
    <view class="nav-item" data-id="plan" bind:tap="onTapTab">
      <image class="nav-icon" src="/assets/illustrations/tab-plan.png" mode="aspectFit" />
      <text class="nav-label">计划</text>
    </view>
    <view class="nav-item nav-item-active" data-id="mine" bind:tap="onTapTab">
      <image class="nav-icon" src="/assets/illustrations/tab-my.png" mode="aspectFit" />
      <text class="nav-label">我的</text>
    </view>
  </view>
</view>
