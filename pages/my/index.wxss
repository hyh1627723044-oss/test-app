.profile-card,
.stats,
.feature-card,
.menu-card {
  box-sizing: border-box;
}

.profile-card {
  position: relative;
  min-height: 190rpx;
  padding: 30rpx 28rpx;
  display: flex;
  flex-direction: row;
  align-items: center;
  overflow: hidden;
}

.profile-tape {
  position: absolute;
  left: 38rpx;
  top: -25rpx;
  width: 150rpx;
  height: 66rpx;
  transform: rotate(-5deg);
}

.profile-heart {
  position: absolute;
  right: 34rpx;
  top: 34rpx;
  width: 24rpx;
  height: 24rpx;
  background-color: #f28b63;
  border: 4rpx solid #2b2119;
  border-radius: 18rpx 18rpx 4rpx 18rpx;
  transform: rotate(45deg);
}

.profile-heart::before {
  content: '';
  position: absolute;
  left: -12rpx;
  top: 0;
  width: 24rpx;
  height: 24rpx;
  border-radius: 18rpx;
  background-color: #f28b63;
  border-left: 4rpx solid #2b2119;
  border-bottom: 4rpx solid #2b2119;
}

.avatar {
  width: 112rpx;
  height: 112rpx;
  border-radius: 58rpx;
  background-color: #c87420;
  border: 5rpx solid #2b2119;
  box-shadow: 6rpx 6rpx 0 rgba(200, 116, 32, 0.24);
  display: flex;
  justify-content: center;
  align-items: center;
  flex-shrink: 0;
}

.avatar-text {
  font-size: 40rpx;
  color: #fff8ef;
  font-weight: 600;
}

.profile-copy {
  flex: 1;
  padding-left: 24rpx;
  padding-right: 52rpx;
}

.eyebrow {
  display: block;
  font-size: 24rpx;
  color: #8a5a34;
  margin-bottom: 8rpx;
}

.profile-name {
  display: block;
  font-size: 42rpx;
  line-height: 52rpx;
  color: #251b14;
  font-weight: 600;
}

.profile-name::after {
  content: '';
  display: block;
  width: 120rpx;
  height: 7rpx;
  margin-top: 6rpx;
  border-radius: 8rpx;
  background-color: #c87420;
  transform: rotate(-2deg);
}

.profile-desc {
  display: block;
  margin-top: 12rpx;
  font-size: 25rpx;
  line-height: 36rpx;
  color: #756a60;
}

.stats {
  margin-top: 24rpx;
  padding: 20rpx 18rpx;
  display: flex;
  flex-direction: row;
  justify-content: space-between;
}

.stat-item {
  width: 198rpx;
  min-height: 112rpx;
  border-radius: 24rpx;
  background-color: #fff4df;
  border: 2rpx dashed #dec8ae;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
}

.stat-value {
  font-size: 42rpx;
  line-height: 50rpx;
  color: #251b14;
  font-weight: 600;
}

.stat-label {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #8a5a34;
}

.feature-card {
  position: relative;
  margin-top: 24rpx;
  padding: 24rpx;
  min-height: 166rpx;
  display: flex;
  flex-direction: row;
  align-items: center;
  overflow: hidden;
}

.feature-tape {
  position: absolute;
  left: 28rpx;
  top: -23rpx;
  width: 138rpx;
  height: 60rpx;
  transform: rotate(-5deg);
}

.my-recipes-image,
.ai-image,
.feature-image {
  width: 128rpx;
  height: 128rpx;
  flex-shrink: 0;
}

.plan-entry-card .feature-image {
  width: 118rpx;
  height: 118rpx;
}

.feature-copy {
  flex: 1;
  min-width: 0;
  padding-left: 24rpx;
  padding-right: 22rpx;
}

.feature-title {
  display: block;
  font-size: 34rpx;
  line-height: 42rpx;
  color: #251b14;
  font-weight: 600;
}

.feature-desc {
  display: block;
  margin-top: 10rpx;
  font-size: 25rpx;
  line-height: 36rpx;
  color: #756a60;
}

.feature-arrow {
  font-size: 50rpx;
  color: #8a5a34;
  flex-shrink: 0;
}

.menu-card {
  position: relative;
  margin-top: 24rpx;
  padding: 30rpx 28rpx 22rpx;
  overflow: hidden;
}

.menu-tape {
  position: absolute;
  right: 34rpx;
  top: -24rpx;
  width: 144rpx;
  height: 62rpx;
  transform: rotate(4deg);
}

.menu-title {
  display: block;
  margin-bottom: 18rpx;
  font-size: 34rpx;
  color: #251b14;
  font-weight: 600;
}

.menu-title::after {
  content: '';
  display: block;
  width: 130rpx;
  height: 6rpx;
  margin-top: 8rpx;
  border-radius: 8rpx;
  background-color: #c87420;
  transform: rotate(-2deg);
}

.menu-line {
  min-height: 58rpx;
  border-bottom: 1px dashed #dec8ae;
  display: flex;
  flex-direction: row;
  align-items: center;
}

.menu-line:last-child {
  border-bottom: 0;
}

.menu-dot {
  width: 14rpx;
  height: 14rpx;
  margin-right: 14rpx;
  border-radius: 10rpx;
  background-color: #c87420;
  flex-shrink: 0;
}

.menu-line-text {
  font-size: 27rpx;
  color: #4d4036;
}

.draw-card {
  position: relative;
  margin-top: 24rpx;
  padding: 30rpx 26rpx 28rpx;
  box-sizing: border-box;
  overflow: hidden;
}

.draw-tape {
  position: absolute;
  left: 42rpx;
  top: -25rpx;
  width: 150rpx;
  height: 66rpx;
  transform: rotate(-4deg);
}

.draw-head {
  display: flex;
  flex-direction: row;
  align-items: flex-start;
}

.draw-copy {
  flex: 1;
  min-width: 0;
}

.draw-eyebrow {
  display: block;
  font-size: 23rpx;
  color: #8a5a34;
}

.draw-title {
  display: block;
  margin-top: 8rpx;
  font-size: 38rpx;
  line-height: 46rpx;
  color: #251b14;
  font-weight: 600;
}

.draw-title::after {
  content: '';
  display: block;
  width: 158rpx;
  height: 6rpx;
  margin-top: 7rpx;
  border-radius: 8rpx;
  background-color: #c87420;
  transform: rotate(-2deg);
}

.draw-desc {
  display: block;
  margin-top: 14rpx;
  font-size: 25rpx;
  line-height: 36rpx;
  color: #756a60;
}

.draw-badge {
  min-width: 88rpx;
  height: 54rpx;
  padding: 0 16rpx;
  border-radius: 18rpx;
  background-color: #fff1dd;
  border: 2rpx solid #e1c6a9;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.draw-badge-text {
  font-size: 24rpx;
  color: #a2672a;
  font-weight: 600;
}

.draw-mode-row {
  margin-top: 22rpx;
  display: flex;
  flex-direction: row;
}

.draw-mode {
  height: 58rpx;
  margin-right: 14rpx;
  padding: 0 28rpx;
  border-radius: 22rpx;
  background-color: #fff6ec;
  border: 2rpx solid #e1c6a9;
  display: flex;
  align-items: center;
  justify-content: center;
}

.draw-mode-active {
  background-color: #2b2119;
  border-color: #2b2119;
}

.draw-mode-text {
  font-size: 25rpx;
  color: #a2672a;
}

.draw-mode-active .draw-mode-text {
  color: #fff8ef;
}

.draw-tag-scroll {
  margin-top: 18rpx;
  white-space: nowrap;
}

.draw-tag-row {
  display: inline-flex;
  flex-direction: row;
}

.draw-tag {
  height: 52rpx;
  margin-right: 12rpx;
  padding: 0 22rpx;
  border-radius: 18rpx;
  background-color: #f8f3ee;
  border: 1px dashed #dec8ae;
  display: flex;
  align-items: center;
  justify-content: center;
}

.draw-tag-active {
  background-color: #dfe9d7;
  border-color: #b7c7a7;
}

.draw-tag-text {
  font-size: 23rpx;
  color: #6f6258;
}

.draw-tag-active .draw-tag-text {
  color: #526343;
  font-weight: 600;
}

.draw-stage {
  min-height: 318rpx;
  margin-top: 24rpx;
  border-radius: 28rpx;
  background-color: #fff7eb;
  border: 2rpx dashed #dec8ae;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.wheel-wrap {
  position: relative;
  width: 316rpx;
  height: 316rpx;
}

.wheel-image {
  position: absolute;
  left: 18rpx;
  top: 18rpx;
  width: 280rpx;
  height: 280rpx;
  transition: transform 1.15s cubic-bezier(0.18, 0.86, 0.24, 1);
}

.wheel-pointer-image {
  position: absolute;
  left: 50%;
  top: -8rpx;
  width: 72rpx;
  height: 112rpx;
  margin-left: -36rpx;
  z-index: 3;
}

.gacha-wrap {
  position: relative;
  width: 330rpx;
  height: 318rpx;
}

.gacha-machine-image {
  position: absolute;
  left: 39rpx;
  top: 0;
  width: 252rpx;
  height: 278rpx;
}

.gacha-capsule-image {
  position: absolute;
  left: 114rpx;
  bottom: 0;
  width: 112rpx;
  height: 92rpx;
  opacity: 0;
  transform: translateY(-46rpx) scale(0.72) rotate(-8deg);
  transition: all 0.38s ease;
}

.gacha-open .gacha-machine-image {
  animation: gachaShake 0.42s ease;
}

.gacha-open .gacha-capsule-image {
  opacity: 1;
  transform: translateY(0) scale(1) rotate(0deg);
}

@keyframes gachaShake {
  0%, 100% { transform: rotate(0deg); }
  25% { transform: rotate(-4deg); }
  50% { transform: rotate(4deg); }
  75% { transform: rotate(-2deg); }
}

.draw-button {
  height: 76rpx;
  margin-top: 22rpx;
  border-radius: 26rpx;
  background-color: #c87420;
  border: 4rpx solid #2b2119;
  box-shadow: 5rpx 5rpx 0 rgba(200, 116, 32, 0.18);
  display: flex;
  align-items: center;
  justify-content: center;
}

.draw-button-text {
  font-size: 29rpx;
  color: #fff8ef;
  font-weight: 600;
}

.draw-result {
  margin-top: 22rpx;
  padding: 22rpx;
  border-radius: 24rpx;
  background-color: #fff6ec;
  border: 2rpx dashed #d8bfa4;
}

.draw-result-label {
  display: block;
  font-size: 22rpx;
  color: #8a5a34;
}

.draw-result-title {
  display: block;
  margin-top: 8rpx;
  font-size: 36rpx;
  line-height: 44rpx;
  color: #251b14;
  font-weight: 600;
}

.draw-result-desc {
  display: block;
  margin-top: 10rpx;
  font-size: 25rpx;
  line-height: 36rpx;
  color: #756a60;
}

.draw-result-tags {
  margin-top: 12rpx;
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
}

.draw-result-tag {
  margin: 0 10rpx 8rpx 0;
  padding: 6rpx 12rpx;
  border-radius: 14rpx;
  background-color: #fff1dd;
  font-size: 22rpx;
  color: #a2672a;
}

.draw-action-row {
  margin-top: 14rpx;
  display: flex;
  flex-direction: row;
}

.draw-action-btn {
  height: 58rpx;
  margin-right: 14rpx;
  padding: 0 22rpx;
  border-radius: 20rpx;
  background-color: #fffaf1;
  border: 2rpx solid #e1c6a9;
  display: flex;
  align-items: center;
  justify-content: center;
}

.draw-action-primary {
  background-color: #2b2119;
  border-color: #2b2119;
}

.draw-action-text {
  font-size: 24rpx;
  color: #8a5a34;
}

.draw-action-primary-text {
  font-size: 24rpx;
  color: #fff8ef;
}
