.page-shell {
  min-height: 100vh;
  padding: 28rpx 28rpx 210rpx;
  box-sizing: border-box;
  background-color: #fbfaf7;
}

.profile-card,
.stats,
.my-recipes-card,
.ai-card,
.menu-card {
  padding: 28rpx;
  box-sizing: border-box;
  background-color: #fffaf1;
  border: 4rpx solid #2b2119;
  border-radius: 28rpx;
  box-shadow: 8rpx 8rpx 0 #ead8c8;
}

.profile-card {
  display: flex;
  flex-direction: row;
  align-items: center;
}

.avatar {
  width: 108rpx;
  height: 108rpx;
  border-radius: 54rpx;
  background-color: #c87420;
  border: 4rpx solid #2b2119;
  display: flex;
  justify-content: center;
  align-items: center;
}

.avatar-text {
  font-size: 38rpx;
  color: #fff8ef;
  font-weight: 600;
}

.profile-copy {
  flex: 1;
  padding-left: 22rpx;
}

.profile-name {
  display: block;
  font-size: 36rpx;
  color: #251b14;
  font-weight: 600;
}

.profile-desc {
  display: block;
  margin-top: 10rpx;
  font-size: 26rpx;
  color: #756a60;
}

.stats {
  margin-top: 22rpx;
  display: flex;
  flex-direction: row;
  justify-content: space-between;
}

.stat-item {
  width: 190rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-value {
  font-size: 40rpx;
  color: #251b14;
  font-weight: 600;
}

.stat-label {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #8a5a34;
}

.my-recipes-card,
.ai-card {
  margin-top: 24rpx;
  display: flex;
  flex-direction: row;
  align-items: center;
}

.my-recipes-image,
.ai-image {
  width: 128rpx;
  height: 128rpx;
  flex-shrink: 0;
}

.my-recipes-copy,
.ai-copy {
  flex: 1;
  padding-left: 24rpx;
}

.my-recipes-title,
.ai-title {
  display: block;
  font-size: 34rpx;
  color: #251b14;
  font-weight: 600;
}

.my-recipes-desc,
.ai-desc {
  display: block;
  margin-top: 10rpx;
  font-size: 25rpx;
  line-height: 36rpx;
  color: #756a60;
}

.menu-card {
  margin-top: 22rpx;
}

.menu-title {
  display: block;
  margin-bottom: 18rpx;
  font-size: 32rpx;
  color: #251b14;
  font-weight: 600;
}

.menu-line {
  display: block;
  padding: 16rpx 0;
  border-bottom: 1px solid #f0e7df;
  font-size: 28rpx;
  color: #4d4036;
}

.bottom-nav {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  height: 170rpx;
  padding: 18rpx 64rpx 24rpx;
  box-sizing: border-box;
  background-color: #fbfaf7;
  border-top: 1px solid #eee5dc;
  display: flex;
  flex-direction: row;
  justify-content: space-between;
}

.nav-item {
  width: 130rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  opacity: 0.58;
}

.nav-item-active {
  opacity: 1;
}

.nav-symbol {
  width: 66rpx;
  height: 66rpx;
  border-radius: 33rpx;
  background-color: #eee0d7;
  color: #251b14;
  font-size: 30rpx;
  line-height: 66rpx;
  text-align: center;
  font-weight: 600;
}

.nav-label {
  margin-top: 8rpx;
  font-size: 28rpx;
  color: #251b14;
}
