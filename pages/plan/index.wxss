.plan-head {
  position: relative;
  padding: 36rpx 30rpx 30rpx;
  overflow: hidden;
}

.head-decor {
  position: absolute;
  border: 4rpx solid #4b321f;
  transform: rotate(24deg);
}

.head-decor-left {
  right: 118rpx;
  top: 26rpx;
  width: 18rpx;
  height: 18rpx;
  border-radius: 6rpx;
  background-color: #ee7f4b;
}

.head-decor-right {
  right: 44rpx;
  top: 34rpx;
  width: 38rpx;
  height: 24rpx;
  border-radius: 28rpx 6rpx 28rpx 6rpx;
  background-color: #d8dfa5;
}

.eyebrow {
  font-size: 24rpx;
  color: #9a5d2f;
}

.page-title {
  display: block;
  margin-top: 10rpx;
  font-size: 48rpx;
  line-height: 58rpx;
  color: #3b2718;
  font-weight: 600;
}

.title-underline {
  width: 146rpx;
  height: 7rpx;
  margin-top: 8rpx;
  border-radius: 8rpx;
  background-color: #ee8e36;
  transform: rotate(-2deg);
}

.page-desc {
  display: block;
  margin-top: 18rpx;
  width: 548rpx;
  font-size: 26rpx;
  line-height: 38rpx;
  color: #72543d;
}

.date-bar {
  margin-top: 24rpx;
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
}

.date-step,
.date-current {
  height: 60rpx;
  padding: 0 20rpx;
  box-sizing: border-box;
  border-radius: 20rpx;
  background-color: #fff9e8;
  border: 2rpx solid #cda978;
  display: flex;
  align-items: center;
}

.date-step {
  border-style: dashed;
}

.date-step-text,
.date-current {
  font-size: 24rpx;
  color: #7d4f2d;
}

.date-current {
  min-width: 214rpx;
  justify-content: center;
  font-weight: 600;
}

.slot-list {
  margin-top: 28rpx;
}

.ai-plan-entry {
  margin-top: 24rpx;
  min-height: 132rpx;
  padding: 18rpx 24rpx;
  display: flex;
  align-items: center;
}

.ai-plan-image {
  width: 102rpx;
  height: 102rpx;
  flex-shrink: 0;
}

.ai-plan-entry-copy {
  flex: 1;
  min-width: 0;
  padding-left: 20rpx;
}

.ai-plan-entry-title,
.ai-plan-entry-desc {
  display: block;
}

.ai-plan-entry-title {
  font-size: 32rpx;
  color: #3b2718;
  font-weight: 600;
}

.ai-plan-entry-desc {
  margin-top: 7rpx;
  font-size: 23rpx;
  color: #72543d;
}

.ai-plan-arrow {
  font-size: 44rpx;
  color: #9a5d2f;
}

.ai-plan-panel {
  margin-top: 18rpx;
  padding: 24rpx;
}

.ai-plan-message {
  padding: 18rpx 20rpx;
  border-radius: 22rpx 22rpx 22rpx 7rpx;
  background-color: #fff0da;
  border: 2rpx solid #c89d68;
}

.ai-plan-message-text {
  font-size: 25rpx;
  line-height: 36rpx;
  color: #4b321f;
}

.ai-plan-input-row {
  margin-top: 18rpx;
  display: flex;
  align-items: center;
}

.ai-plan-input {
  flex: 1;
  height: 72rpx;
  padding: 0 18rpx;
  box-sizing: border-box;
  border-radius: 22rpx;
  background-color: #fff9e8;
  border: 2rpx solid #cfa46f;
  color: #3b2718;
  font-size: 25rpx;
}

.ai-plan-send {
  width: 116rpx;
  height: 72rpx;
  margin-left: 12rpx;
  border-radius: 22rpx;
  background-color: #ee8e36;
  border: 3rpx solid #6f5137;
  display: flex;
  align-items: center;
  justify-content: center;
}

.ai-plan-send-disabled {
  opacity: 0.58;
}

.ai-plan-send-text {
  font-size: 24rpx;
  color: #fff6df;
  font-weight: 600;
}

.ai-plan-proposal {
  margin-top: 20rpx;
}

.ai-plan-item {
  padding: 16rpx 0;
  border-bottom: 2rpx dashed #cda978;
  display: flex;
  align-items: flex-start;
}

.ai-plan-slot {
  width: 106rpx;
  margin-right: 14rpx;
  padding: 7rpx 10rpx;
  box-sizing: border-box;
  border-radius: 14rpx;
  background-color: #d8dfa5;
  color: #68753f;
  font-size: 21rpx;
  text-align: center;
}

.ai-plan-item-copy {
  flex: 1;
}

.ai-plan-dish,
.ai-plan-reason {
  display: block;
}

.ai-plan-dish {
  font-size: 27rpx;
  color: #3b2718;
  font-weight: 600;
}

.ai-plan-reason {
  margin-top: 6rpx;
  font-size: 22rpx;
  line-height: 32rpx;
  color: #72543d;
}

.ai-plan-confirm {
  height: 70rpx;
  margin-top: 20rpx;
  border-radius: 24rpx;
  background-color: #ee8e36;
  border: 3rpx solid #6f5137;
  display: flex;
  align-items: center;
  justify-content: center;
}

.ai-plan-confirm-text {
  font-size: 26rpx;
  color: #fff6df;
  font-weight: 600;
}

.slot-card {
  position: relative;
  min-height: 160rpx;
  margin-bottom: 24rpx;
  padding: 26rpx 24rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: row;
  overflow: hidden;
}

.slot-tape {
  position: absolute;
  left: 28rpx;
  top: -25rpx;
  width: 146rpx;
  height: 64rpx;
  transform: rotate(-5deg);
  z-index: 2;
}

.slot-decor {
  position: absolute;
  right: 24rpx;
  top: 18rpx;
  width: 76rpx;
  height: 76rpx;
}

.slot-left {
  width: 158rpx;
  padding-right: 18rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.slot-time {
  font-size: 24rpx;
  color: #9a5d2f;
  font-weight: 600;
}

.slot-name {
  margin-top: 8rpx;
  font-size: 36rpx;
  line-height: 44rpx;
  color: #3b2718;
  font-weight: 600;
}

.slot-hint {
  margin-top: 8rpx;
  font-size: 20rpx;
  color: #a47b59;
}

.slot-content {
  flex: 1;
  min-width: 0;
  padding: 8rpx 72rpx 0 0;
  box-sizing: border-box;
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  align-items: center;
  border-left: 2rpx dashed #cda978;
  padding-left: 22rpx;
}

.recipe-chip {
  max-width: 320rpx;
  margin: 8rpx 10rpx 8rpx 0;
  padding: 12rpx 18rpx;
  border-radius: 18rpx;
  background-color: #ffe2b5;
  border: 2rpx solid #cfa46f;
  display: flex;
  flex-direction: row;
  align-items: center;
}

.recipe-chip-action {
  margin-left: 14rpx;
  padding-left: 14rpx;
  border-left: 1px dashed #c89d68;
  font-size: 22rpx;
  color: #a76225;
  flex-shrink: 0;
}

.recipe-dot {
  width: 12rpx;
  height: 12rpx;
  margin-right: 10rpx;
  border-radius: 8rpx;
  background-color: #ee8e36;
}

.recipe-chip-text {
  font-size: 26rpx;
  color: #63452f;
}

.empty-slot {
  display: flex;
  flex-direction: row;
  align-items: center;
}

.empty-slot-image {
  width: 84rpx;
  height: 84rpx;
  margin-right: 14rpx;
  opacity: 0.9;
}

.empty-text {
  font-size: 26rpx;
  color: #9e8068;
}

.choose-card {
  margin-top: 6rpx;
  padding: 24rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
}

.choose-copy {
  flex: 1;
  min-width: 0;
}

.choose-title {
  display: block;
  font-size: 30rpx;
  color: #3b2718;
  font-weight: 600;
}

.choose-desc {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  line-height: 34rpx;
  color: #72543d;
}

.choose-btn {
  width: 134rpx;
  height: 58rpx;
  margin-left: 18rpx;
  border-radius: 20rpx;
  background-color: #ee8e36;
  border: 4rpx solid #4b321f;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
}

.choose-btn-text {
  font-size: 24rpx;
  color: #fff6df;
  font-weight: 600;
}
