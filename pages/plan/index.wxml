<view class="page-shell">
  <view class="plan-head paper-card paper-hero">
    <view class="head-decor head-decor-left"></view>
    <view class="head-decor head-decor-right"></view>
    <text class="eyebrow">{{dateText}}</text>
    <text class="page-title">今日计划</text>
    <view class="title-underline"></view>
    <text class="page-desc">把想吃的菜安排到早餐、午餐、晚餐，也可以加下午茶和夜宵。</text>
    <view class="date-bar">
      <view class="date-step" bind:tap="onPrevDay">
        <text class="date-step-text">前一天</text>
      </view>
      <picker mode="date" value="{{planDate}}" bind:change="onChangeDate">
        <view class="date-current">{{planDate}}</view>
      </picker>
      <view class="date-step" bind:tap="onNextDay">
        <text class="date-step-text">后一天</text>
      </view>
    </view>
  </view>

  <view class="ai-plan-entry paper-card" bind:tap="onToggleAiPlanner">
    <image class="ai-plan-image" src="/assets/illustrations/ai-chef.png" mode="aspectFit" />
    <view class="ai-plan-entry-copy">
      <text class="ai-plan-entry-title">AI 帮我安排</text>
      <text class="ai-plan-entry-desc">可以只问一餐，勾选满意的建议再加入。</text>
    </view>
    <text class="ai-plan-arrow">{{showAiPlanner ? '⌃' : '›'}}</text>
  </view>

  <view class="ai-plan-panel paper-card" wx:if="{{showAiPlanner}}">
    <view class="ai-plan-message">
      <text class="ai-plan-message-text">{{aiPlanReply}}</text>
    </view>
    <view class="ai-plan-input-row">
      <input
        class="ai-plan-input"
        value="{{aiPlanInput}}"
        placeholder="例如：两个人，晚餐想清淡一点..."
        confirm-type="send"
        bind:input="onInputAiPlan"
        bind:confirm="onAskAiPlan"
      />
      <view class="ai-plan-send {{aiPlanSending ? 'ai-plan-send-disabled' : ''}}" bind:tap="onAskAiPlan">
        <text class="ai-plan-send-text">{{aiPlanSending ? '思考中' : '发送'}}</text>
      </view>
    </view>
    <view class="ai-plan-proposal" wx:if="{{aiPlanProposal.length > 0}}">
      <view
        class="ai-plan-item {{item.selected ? 'ai-plan-item-selected' : 'ai-plan-item-unselected'}}"
        wx:for="{{aiPlanProposal}}"
        wx:key="meal_slot"
        data-index="{{index}}"
        bind:tap="onToggleAiPlanItem"
        aria-label="{{item.selected ? '取消选择' : '选择'}}{{item.title}}"
      >
        <view class="ai-plan-check {{item.selected ? 'ai-plan-check-selected' : ''}}">
          <text wx:if="{{item.selected}}" class="ai-plan-check-mark">✓</text>
        </view>
        <text class="ai-plan-slot">{{item.meal_slot_label}}</text>
        <view class="ai-plan-item-copy">
          <text class="ai-plan-dish">{{item.title}}</text>
          <text class="ai-plan-reason">{{item.reason}}</text>
        </view>
      </view>
      <view class="ai-plan-confirm" bind:tap="onConfirmAiPlan">
        <text class="ai-plan-confirm-text">确认加入计划（{{aiPlanSelectedCount}}）</text>
      </view>
    </view>
  </view>

  <view class="slot-list">
    <view class="slot-card paper-card slot-card-{{item.decor_type}}" wx:for="{{slots}}" wx:key="id">
      <image class="slot-tape" src="/assets/illustrations/tape-{{item.tape_color}}.png" mode="aspectFit" />
      <image class="slot-decor" src="/assets/illustrations/decor-{{item.decor_type}}.png" mode="aspectFit" />
      <view class="slot-left">
        <text class="slot-time">{{item.time}}</text>
        <text class="slot-name">{{item.name}}</text>
        <text class="slot-hint">今日便签</text>
      </view>
      <view class="slot-content">
        <block wx:if="{{item.recipes.length > 0}}">
          <view
            class="planned-recipe"
            wx:for="{{item.recipes}}"
            wx:key="id"
            wx:for-item="recipe"
            data-id="{{recipe.id}}"
            data-item-id="{{recipe.item_id}}"
            data-slot="{{item.id}}"
            bind:tap="onTapRecipe"
          >
            <view class="planned-cover">
              <image
                wx:if="{{recipe.cover}}"
                class="planned-cover-image"
                src="{{recipe.cover}}"
                mode="aspectFill"
              />
              <image
                wx:else
                class="planned-cover-empty"
                src="/assets/illustrations/empty-plan.png"
                mode="aspectFit"
              />
            </view>
            <view class="planned-copy">
              <text class="planned-title">{{recipe.title}}</text>
              <text class="planned-note" wx:if="{{recipe.note}}">{{recipe.note}}</text>
            </view>
            <text
              class="planned-action"
              data-item-id="{{recipe.item_id}}"
              data-slot="{{item.id}}"
              catchtap="onManagePlanItem"
            >管理</text>
          </view>
        </block>
        <view wx:else class="empty-slot">
          <image class="empty-slot-image" src="/assets/illustrations/empty-plan.png" mode="aspectFit" />
          <text class="empty-text">还没安排</text>
        </view>
      </view>
    </view>
  </view>

  <view class="choose-card paper-dashed-card" bind:tap="onTapChooseRecipes">
    <view class="choose-copy">
      <text class="choose-title">还想加一道？</text>
      <text class="choose-desc">去菜谱里挑一挑，把它安排进今天。</text>
    </view>
    <view class="choose-btn">
      <text class="choose-btn-text">去选菜</text>
    </view>
  </view>

  <view class="bottom-nav">
    <view class="nav-item" data-id="recipes" bind:tap="onTapTab">
      <image class="nav-icon" src="/assets/illustrations/tab-recipes.png" mode="aspectFit" />
      <text class="nav-label">菜单</text>
    </view>
    <view class="nav-item nav-item-active" data-id="plan" bind:tap="onTapTab">
      <image class="nav-icon" src="/assets/illustrations/tab-plan.png" mode="aspectFit" />
      <text class="nav-label">计划</text>
    </view>
    <view class="nav-item" data-id="mine" bind:tap="onTapTab">
      <image class="nav-icon" src="/assets/illustrations/tab-my.png" mode="aspectFit" />
      <text class="nav-label">我的</text>
    </view>
  </view>
</view>
