.manage-hero {
  min-height: 194rpx;
  padding: 24rpx 28rpx;
  display: flex;
  align-items: center;
}

.manage-pot {
  width: 140rpx;
  height: 140rpx;
  flex-shrink: 0;
}

.manage-copy {
  flex: 1;
  padding-left: 22rpx;
}

.manage-eyebrow,
.manage-title,
.manage-desc {
  display: block;
}

.manage-eyebrow {
  font-size: 23rpx;
  color: #9a5d2f;
}

.manage-title {
  margin-top: 6rpx;
  font-size: 40rpx;
  color: #3b2718;
  font-weight: 600;
}

.manage-desc {
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 34rpx;
  color: #72543d;
}

.add-recipe-btn {
  height: 82rpx;
  margin-top: 24rpx;
  border-radius: 28rpx;
  background-color: #ee8e36;
  border: 4rpx solid #6f5137;
  box-shadow: 6rpx 7rpx 0 rgba(196, 105, 31, 0.24);
  display: flex;
  align-items: center;
  justify-content: center;
}

.add-recipe-text {
  color: #fff6df;
  font-size: 30rpx;
  font-weight: 600;
}

.empty-state {
  margin-top: 26rpx;
  padding: 40rpx 26rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.empty-image {
  width: 180rpx;
  height: 180rpx;
}

.empty-title {
  margin-top: 8rpx;
  color: #3b2718;
  font-size: 32rpx;
  font-weight: 600;
}

.empty-desc {
  margin-top: 10rpx;
  color: #72543d;
  font-size: 24rpx;
}

.recipe-list {
  margin-top: 26rpx;
}

.manage-recipe {
  position: relative;
  min-height: 238rpx;
  margin-bottom: 24rpx;
  padding: 20rpx;
  display: flex;
  overflow: visible;
}

.manage-tape {
  position: absolute;
  left: 34rpx;
  top: -24rpx;
  width: 136rpx;
  height: 60rpx;
  transform: rotate(-7deg);
  pointer-events: none;
  z-index: 2;
}

.manage-decor {
  position: absolute;
  right: 22rpx;
  top: 16rpx;
  width: 68rpx;
  height: 68rpx;
  pointer-events: none;
  z-index: 2;
}

.manage-cover {
  width: 190rpx;
  height: 190rpx;
  border-radius: 20rpx;
  overflow: hidden;
  background-color: #f0c993;
  flex-shrink: 0;
}

.manage-cover-image,
.manage-cover-empty {
  width: 190rpx;
  height: 190rpx;
}

.manage-cover-empty {
  display: flex;
  align-items: center;
  justify-content: center;
  color: #a75d23;
  font-size: 66rpx;
  font-weight: 600;
}

.manage-info {
  flex: 1;
  min-width: 0;
  padding: 6rpx 54rpx 0 20rpx;
}

.manage-recipe-title,
.manage-recipe-desc {
  display: block;
}

.manage-recipe-title {
  color: #3b2718;
  font-size: 31rpx;
  font-weight: 600;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.manage-recipe-desc {
  margin-top: 8rpx;
  color: #72543d;
  font-size: 22rpx;
  line-height: 30rpx;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.manage-tags {
  margin-top: 10rpx;
  white-space: nowrap;
  overflow: hidden;
}

.manage-tag {
  display: inline-block;
  margin-right: 8rpx;
  padding: 4rpx 9rpx;
  border-radius: 12rpx;
  background-color: #d8dfa5;
  color: #68753f;
  font-size: 19rpx;
}

.manage-actions {
  margin-top: 12rpx;
  display: flex;
}

.manage-action {
  min-width: 84rpx;
  height: 48rpx;
  margin-right: 10rpx;
  border-radius: 16rpx;
  background-color: #ffe2b5;
  border: 2rpx solid #cfa46f;
  color: #7d4f2d;
  font-size: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.manage-action-danger {
  background-color: #fff0da;
  border-color: #ee7f4b;
  color: #b95833;
}
