<view class="page-shell">
  <view class="hero paper-card paper-hero">
    <view class="hero-copy">
      <text class="eyebrow">今日菜单</text>
      <text class="hero-title">今天想吃点什么？</text>
      <text class="hero-desc">挑一道菜，加入早餐、午餐、晚餐或夜宵计划。</text>
    </view>
  </view>

  <view class="search-card paper-card">
    <view class="search-top">
      <view class="search-box">
        <input
          class="search-input"
          placeholder="搜索菜名 / 标签"
          value="{{searchKeyword}}"
          confirm-type="search"
          bind:input="onInputSearch"
          bind:confirm="onConfirmSearch"
        />
        <view wx:if="{{searchKeyword}}" class="search-clear" bind:tap="onClearSearch">
          <text class="search-clear-text">清空</text>
        </view>
      </view>
      <image class="search-mascot" src="/assets/illustrations/search-cat.png" mode="aspectFit" />
    </view>
    <view class="quick-filter-bar">
      <scroll-view class="quick-tag-scroll" scroll-x>
        <view class="quick-tag-row">
          <view
            class="quick-tag {{activeQuickTag === item ? 'quick-tag-active' : ''}}"
            wx:for="{{quickTags}}"
            wx:key="*this"
            data-tag="{{item}}"
            bind:tap="onTapQuickTag"
          >
            <text class="quick-tag-text">{{item}}</text>
          </view>
          <view class="quick-tag quick-tag-more" bind:tap="onTapManageTags">
            <text class="quick-tag-text">+</text>
          </view>
        </view>
      </scroll-view>
    </view>
  </view>

  <view class="category-bar">
    <scroll-view class="category-strip" scroll-x>
      <view
        class="category-pill {{activeCategory === item ? 'category-pill-active' : ''}}"
        wx:for="{{categories}}"
        wx:key="*this"
        data-name="{{item}}"
        bind:tap="onTapCategory"
      >
        <text class="category-text">{{item}}</text>
      </view>
    </scroll-view>
    <view class="add-recipe-icon-btn" bind:tap="onTapAddRecipe" aria-label="添加菜谱">
      <image class="add-recipe-icon" src="/assets/illustrations/icon-recipe-add.png" mode="aspectFit" />
      <text class="add-recipe-text">添加菜谱</text>
    </view>
  </view>

  <view class="recipe-list">
    <view wx:if="{{displayRecipes.length === 0}}" class="empty-state paper-card">
      <image class="empty-image" src="/assets/illustrations/empty-recipes.png" mode="aspectFit" />
      <text class="empty-title">还没找到这道菜</text>
      <text class="empty-desc">换个菜名或标签试试，也可以先添加自己的菜谱。</text>
    </view>
    <block wx:if="{{displayRecipes.length > 0}}">
    <view
      class="recipe-card paper-card"
      wx:for="{{displayRecipes}}"
      wx:key="id"
      data-id="{{item.id}}"
      bind:tap="onTapRecipe"
    >
      <image class="card-tape" src="/assets/illustrations/tape-{{item.tape_color}}.png" mode="aspectFit" />
      <image class="card-decor" src="/assets/illustrations/decor-{{item.decor_type}}.png" mode="aspectFit" />
      <view class="recipe-cover">
        <block wx:if="{{item.primary_cover_file_id}}">
        <image
          class="recipe-cover-image"
          src="{{item.primary_cover_file_id}}"
          mode="aspectFill"
          lazy-load
        />
        </block>
        <block wx:if="{{!item.primary_cover_file_id}}">
        <view class="recipe-cover-empty">
          <text class="recipe-cover-title">{{item.title}}</text>
        </view>
        </block>
      </view>
      <view class="recipe-info">
        <text class="recipe-title">{{item.title}}</text>
        <view class="time-line">
          <text class="time-icon">◷</text>
          <text class="time-text">{{item.cook_time_minutes}} 分钟</text>
        </view>
        <text class="recipe-desc">{{item.description}}</text>
        <view class="recipe-tag-row" wx:if="{{item.tags.length > 0}}">
          <text class="recipe-tag" wx:for="{{item.tags}}" wx:key="*this">#{{item}}</text>
        </view>
        <view class="recipe-action-row">
          <view class="action-divider"></view>
          <view class="plan-btn" data-id="{{item.id}}" catchtap="onTapAddToPlan">
            <image class="plan-btn-icon" src="/assets/illustrations/icon-plan-add.png" mode="aspectFit" />
            <text class="plan-btn-text">加入计划</text>
          </view>
        </view>
      </view>
    </view>
    </block>
  </view>

  <view class="bottom-nav">
    <view class="nav-item nav-item-active" data-id="recipes" bind:tap="onTapTab">
      <image class="nav-icon nav-icon-recipes" src="/assets/illustrations/tab-recipes.png" mode="aspectFit" />
      <text class="nav-label">菜单</text>
    </view>

    <view class="nav-item" data-id="plan" bind:tap="onTapTab">
      <image class="nav-icon" src="/assets/illustrations/tab-plan.png" mode="aspectFit" />
      <text class="nav-label">计划</text>
    </view>

    <view class="nav-item" data-id="mine" bind:tap="onTapTab">
      <image class="nav-icon" src="/assets/illustrations/tab-my.png" mode="aspectFit" />
      <text class="nav-label">我的</text>
    </view>
  </view>
</view>
