.page-shell {
  min-height: 100vh;
  padding: 28rpx 28rpx 210rpx;
  box-sizing: border-box;
  background-color: #fbfaf7;
}

.hero {
  min-height: 238rpx;
  padding: 34rpx 30rpx;
  box-sizing: border-box;
  background-color: #eee0d7;
  border-radius: 28rpx;
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: flex-end;
}

.hero-copy {
  width: 430rpx;
  display: flex;
  flex-direction: column;
}

.eyebrow {
  font-size: 24rpx;
  color: #8a5a34;
  margin-bottom: 14rpx;
}

.hero-title {
  font-size: 44rpx;
  line-height: 54rpx;
  color: #271b12;
  font-weight: 600;
}

.hero-desc {
  margin-top: 18rpx;
  font-size: 26rpx;
  line-height: 36rpx;
  color: #755f4d;
}

.hero-action {
  min-width: 154rpx;
  height: 66rpx;
  padding: 0 22rpx;
  box-sizing: border-box;
  background-color: #c87420;
  border: 4rpx solid #2b2119;
  border-radius: 28rpx;
  display: flex;
  justify-content: center;
  align-items: center;
}

.hero-action-text {
  font-size: 26rpx;
  color: #fff8ef;
}

.search-card {
  margin-top: 22rpx;
  padding: 18rpx 18rpx 10rpx;
  box-sizing: border-box;
  border-radius: 28rpx;
  background-color: #fffaf1;
  border: 4rpx solid #2b2119;
  box-shadow: 8rpx 8rpx 0 #ead8c8;
}

.search-top {
  display: flex;
  flex-direction: row;
  align-items: center;
}

.search-box {
  flex: 1;
  height: 74rpx;
  padding: 0 18rpx;
  box-sizing: border-box;
  border-radius: 20rpx;
  background-color: #f8f3ee;
  border: 1px solid #ecd9c8;
  display: flex;
  flex-direction: row;
  align-items: center;
}

.search-mascot {
  width: 148rpx;
  height: 90rpx;
  margin-left: 14rpx;
  flex-shrink: 0;
}

.search-input {
  flex: 1;
  height: 74rpx;
  font-size: 28rpx;
  color: #251b14;
}

.search-clear {
  padding: 8rpx 14rpx;
  border-radius: 14rpx;
  background-color: #eee0d7;
}

.search-clear-text {
  font-size: 24rpx;
  color: #8a5a34;
}

.quick-tag-row {
  margin-top: 16rpx;
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
}

.quick-tag {
  margin: 0 12rpx 12rpx 0;
  padding: 8rpx 16rpx;
  border-radius: 16rpx;
  background-color: #fff6ec;
}

.quick-tag-active {
  background-color: #2b2119;
}

.quick-tag-text {
  font-size: 24rpx;
  color: #a2672a;
}

.quick-tag-active .quick-tag-text {
  color: #fff8ef;
}

.category-strip {
  white-space: nowrap;
  margin: 26rpx 0;
}

.category-pill {
  display: inline-flex;
  height: 58rpx;
  padding: 0 28rpx;
  margin-right: 16rpx;
  border-radius: 24rpx;
  border: 1px solid #e2d6cb;
  background-color: #ffffff;
  align-items: center;
}

.category-pill-active {
  background-color: #2b2119;
  border-color: #2b2119;
}

.category-text {
  font-size: 26rpx;
  color: #6f6258;
}

.category-pill-active .category-text {
  color: #fff8ef;
}

.recipe-list {
  display: flex;
  flex-direction: column;
}

.empty-state {
  padding: 42rpx 28rpx;
  box-sizing: border-box;
  border-radius: 30rpx;
  background-color: #fffaf1;
  border: 4rpx solid #2b2119;
  box-shadow: 8rpx 8rpx 0 #ead8c8;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.empty-image {
  width: 190rpx;
  height: 190rpx;
}

.empty-title {
  margin-top: 10rpx;
  font-size: 32rpx;
  color: #251b14;
  font-weight: 600;
}

.empty-desc {
  margin-top: 12rpx;
  font-size: 25rpx;
  line-height: 36rpx;
  color: #756a60;
  text-align: center;
}

.recipe-card {
  position: relative;
  min-height: 450rpx;
  padding: 18rpx 18rpx 20rpx;
  margin-bottom: 28rpx;
  box-sizing: border-box;
  background-color: #fffaf1;
  border: 4rpx solid #2b2119;
  border-radius: 30rpx;
  box-shadow: 8rpx 8rpx 0 #ead8c8;
  display: flex;
  flex-direction: column;
}

.card-tape {
  position: absolute;
  left: 46rpx;
  top: -16rpx;
  width: 126rpx;
  height: 34rpx;
  border-radius: 10rpx;
  background-color: rgba(217, 173, 120, 0.72);
  transform: rotate(-4deg);
  z-index: 2;
}

.recipe-cover {
  position: relative;
  width: 100%;
  height: 260rpx;
  border-radius: 24rpx;
  overflow: hidden;
  background-color: #f3dcc6;
  border: 1px solid #ead2bd;
}

.recipe-cover-image {
  width: 100%;
  height: 260rpx;
}

.recipe-cover-empty {
  position: relative;
  width: 100%;
  height: 260rpx;
  display: flex;
  justify-content: center;
  align-items: center;
}

.recipe-letter-card {
  position: absolute;
  left: 50%;
  top: 50%;
  width: 190rpx;
  height: 190rpx;
  margin-left: -95rpx;
  margin-top: -95rpx;
  border-radius: 95rpx;
  background-color: #fff8ef;
  border: 5rpx solid #2b2119;
  box-shadow: 8rpx 8rpx 0 rgba(200, 116, 32, 0.22);
  display: flex;
  align-items: center;
  justify-content: center;
}

.recipe-cover-letter {
  font-size: 82rpx;
  line-height: 96rpx;
  color: #9d5d24;
  font-weight: 600;
}

.letter-spark {
  position: absolute;
  width: 18rpx;
  height: 18rpx;
  border-radius: 6rpx;
  background-color: #c87420;
  border: 4rpx solid #2b2119;
  transform: rotate(28deg);
}

.letter-spark-left {
  left: -20rpx;
  top: 28rpx;
}

.letter-spark-right {
  right: -10rpx;
  top: 48rpx;
}

.letter-leaf {
  position: absolute;
  width: 34rpx;
  height: 20rpx;
  background-color: #dfe9d7;
  border: 4rpx solid #2b2119;
  border-radius: 28rpx 4rpx 28rpx 4rpx;
}

.letter-leaf-left {
  left: 28rpx;
  bottom: 24rpx;
  transform: rotate(18deg);
}

.letter-leaf-right {
  right: 28rpx;
  bottom: 24rpx;
  transform: rotate(-18deg) scaleX(-1);
}

.time-badge {
  position: absolute;
  right: 18rpx;
  top: 18rpx;
  padding: 8rpx 16rpx;
  border-radius: 18rpx;
  background-color: #fff8ef;
  border: 3rpx solid #2b2119;
}

.time-badge-text {
  font-size: 23rpx;
  color: #8a5a34;
  font-weight: 600;
}

.recipe-info {
  padding: 20rpx 4rpx 0;
  display: flex;
  flex-direction: column;
}

.recipe-title-row {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
}

.recipe-title {
  flex: 1;
  font-size: 36rpx;
  color: #251b14;
  font-weight: 600;
}

.recipe-desc {
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 34rpx;
  color: #756a60;
}

.recipe-meal {
  margin-left: 16rpx;
  padding: 6rpx 14rpx;
  border-radius: 16rpx;
  background-color: #dfe9d7;
  font-size: 22rpx;
  color: #526343;
  flex-shrink: 0;
}

.recipe-tag-row {
  margin-top: 12rpx;
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
}

.recipe-tag {
  margin: 0 10rpx 8rpx 0;
  padding: 6rpx 12rpx;
  border-radius: 14rpx;
  background-color: #fff1dd;
  font-size: 22rpx;
  color: #a2672a;
}

.recipe-action-row {
  margin-top: 14rpx;
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
}

.recipe-note {
  font-size: 23rpx;
  color: #9a8b7d;
}

.plan-btn {
  min-width: 146rpx;
  height: 56rpx;
  padding: 0 18rpx;
  box-sizing: border-box;
  border-radius: 20rpx;
  background-color: #c87420;
  border: 4rpx solid #2b2119;
  display: flex;
  align-items: center;
  justify-content: center;
}

.plan-btn-text {
  font-size: 24rpx;
  color: #fff8ef;
  font-weight: 600;
}

.bottom-nav {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  height: 188rpx;
  padding: 14rpx 42rpx 22rpx;
  box-sizing: border-box;
  background-color: #fbfaf7;
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: flex-end;
  border-top: 1px solid #eee5dc;
}

.nav-item {
  width: 160rpx;
  height: 150rpx;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  align-items: center;
  opacity: 0.62;
}

.nav-item-active {
  opacity: 1;
}

.nav-icon {
  width: 108rpx;
  height: 92rpx;
}

.nav-label {
  margin-top: 4rpx;
  font-size: 34rpx;
  line-height: 40rpx;
  color: #251b14;
  font-weight: 500;
}
