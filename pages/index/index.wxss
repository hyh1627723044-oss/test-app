.hero {
  min-height: 238rpx;
  padding: 34rpx 30rpx;
  box-sizing: border-box;
}

.hero-copy {
  width: 100%;
  display: flex;
  flex-direction: column;
}

.eyebrow {
  font-size: 24rpx;
  color: #9a5d2f;
  margin-bottom: 14rpx;
}

.hero-title {
  font-size: 44rpx;
  line-height: 54rpx;
  color: #3b2718;
  font-weight: 600;
}

.hero-desc {
  margin-top: 18rpx;
  font-size: 26rpx;
  line-height: 36rpx;
  color: #72543d;
}

.search-card {
  margin-top: 22rpx;
  padding: 18rpx 18rpx 10rpx;
  box-sizing: border-box;
}

.search-top {
  display: flex;
  flex-direction: row;
  align-items: center;
}

.search-box {
  flex: 1;
  height: 74rpx;
  padding: 0 18rpx;
  box-sizing: border-box;
  border-radius: 20rpx;
  background-color: #f8e8cf;
  border: 1px solid #d9b98d;
  display: flex;
  flex-direction: row;
  align-items: center;
}

.search-mascot {
  width: 148rpx;
  height: 90rpx;
  margin-left: 14rpx;
  flex-shrink: 0;
}

.search-input {
  flex: 1;
  height: 74rpx;
  font-size: 28rpx;
  color: #3b2718;
}

.search-clear {
  padding: 8rpx 14rpx;
  border-radius: 14rpx;
  background-color: #efd2aa;
}

.search-clear-text {
  font-size: 24rpx;
  color: #9a5d2f;
}

.quick-filter-bar {
  margin-top: 16rpx;
  display: flex;
  flex-direction: row;
  align-items: flex-start;
}

.quick-tag-scroll {
  flex: 1;
  white-space: nowrap;
}

.quick-tag-row {
  display: inline-flex;
  flex-direction: row;
  align-items: center;
  white-space: nowrap;
}

.quick-tag {
  height: 54rpx;
  margin: 0 12rpx 12rpx 0;
  padding: 0 24rpx;
  border-radius: 18rpx;
  background-color: #fff0da;
  border: 2rpx solid #cfa46f;
  box-sizing: border-box;
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
}

.quick-tag-more {
  width: 64rpx;
  padding: 0;
  border-style: dashed;
  background-color: #fff9e8;
}

.quick-tag-active {
  background-color: #4b321f;
}

.quick-tag-text {
  font-size: 24rpx;
  color: #a76225;
}

.quick-tag-active .quick-tag-text {
  color: #fff6df;
}

.add-recipe-mini {
  width: 136rpx;
  height: 54rpx;
  margin-left: 12rpx;
  border-radius: 18rpx;
  background-color: #ee8e36;
  border: 4rpx solid #4b321f;
  box-sizing: border-box;
  box-shadow: 4rpx 4rpx 0 #d7b88f;
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.add-recipe-mini-text {
  font-size: 24rpx;
  color: #fff6df;
  font-weight: 600;
}

.category-strip {
  white-space: nowrap;
  margin: 26rpx 0;
}

.category-pill {
  display: inline-flex;
  height: 58rpx;
  padding: 0 28rpx;
  margin-right: 16rpx;
  border-radius: 24rpx;
  border: 1px solid #d8b98f;
  background-color: #fff9e8;
  align-items: center;
}

.category-pill-active {
  background-color: #4b321f;
  border-color: #4b321f;
}

.category-text {
  font-size: 26rpx;
  color: #70533d;
}

.category-pill-active .category-text {
  color: #fff6df;
}

.recipe-list {
  display: flex;
  flex-direction: column;
}

.empty-state {
  padding: 42rpx 28rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.empty-image {
  width: 190rpx;
  height: 190rpx;
}

.empty-title {
  margin-top: 10rpx;
  font-size: 32rpx;
  color: #3b2718;
  font-weight: 600;
}

.empty-desc {
  margin-top: 12rpx;
  font-size: 25rpx;
  line-height: 36rpx;
  color: #72543d;
  text-align: center;
}

.recipe-card {
  position: relative;
  min-height: 300rpx;
  padding: 22rpx 24rpx;
  margin-bottom: 28rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: row;
  align-items: stretch;
  overflow: visible;
}

.card-tape {
  position: absolute;
  left: 46rpx;
  top: -26rpx;
  width: 142rpx;
  height: 66rpx;
  transform: rotate(-9deg);
  z-index: 2;
}

.card-decor {
  position: absolute;
  right: 28rpx;
  top: 30rpx;
  width: 74rpx;
  height: 74rpx;
  z-index: 3;
}

.recipe-cover {
  position: relative;
  width: 270rpx;
  height: 244rpx;
  border-radius: 16rpx;
  overflow: hidden;
  background-color: #f0c993;
  border: 1px solid #d7b17e;
  flex-shrink: 0;
}

.recipe-cover-image {
  width: 270rpx;
  height: 244rpx;
}

.recipe-cover-empty {
  position: relative;
  width: 270rpx;
  height: 244rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 22rpx;
  box-sizing: border-box;
}

.recipe-cover-title {
  width: 100%;
  color: #8a4f1c;
  font-size: 48rpx;
  line-height: 58rpx;
  color: #a75d23;
  font-weight: 600;
  text-align: center;
  word-break: break-all;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.recipe-info {
  flex: 1;
  min-width: 0;
  padding: 18rpx 66rpx 0 28rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
}

.recipe-title {
  display: block;
  width: 100%;
  font-size: 38rpx;
  line-height: 48rpx;
  color: #3b2718;
  font-weight: 600;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.time-line {
  margin-top: 10rpx;
  display: flex;
  flex-direction: row;
  align-items: center;
}

.time-icon {
  margin-right: 8rpx;
  font-size: 24rpx;
  color: #6f5137;
}

.time-text {
  font-size: 24rpx;
  color: #6f5137;
}

.recipe-desc {
  margin-top: 10rpx;
  font-size: 25rpx;
  line-height: 36rpx;
  color: #72543d;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.recipe-meal {
  margin-left: 16rpx;
  padding: 6rpx 14rpx;
  border-radius: 16rpx;
  background-color: #d8dfa5;
  font-size: 22rpx;
  color: #68753f;
  flex-shrink: 0;
}

.recipe-tag-row {
  margin-top: 14rpx;
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
}

.recipe-tag {
  margin: 0 10rpx 8rpx 0;
  padding: 6rpx 12rpx;
  border-radius: 14rpx;
  background-color: #ffe2b5;
  font-size: 22rpx;
  color: #a76225;
}

.recipe-action-row {
  margin-top: auto;
  display: flex;
  flex-direction: row;
  justify-content: flex-end;
  align-items: center;
}

.action-divider {
  position: absolute;
  left: 322rpx;
  right: 156rpx;
  bottom: 82rpx;
  height: 0;
  border-top: 2rpx dashed #d7b88f;
}

.plan-btn {
  min-width: 176rpx;
  height: 58rpx;
  padding: 0 20rpx;
  box-sizing: border-box;
  border-radius: 22rpx;
  background-color: #ee8e36;
  border: 4rpx solid #4b321f;
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  z-index: 4;
}

.plan-btn-icon {
  width: 30rpx;
  height: 30rpx;
  margin-right: 10rpx;
  flex-shrink: 0;
}

.plan-btn-text {
  font-size: 24rpx;
  color: #fff6df;
  font-weight: 600;
}
