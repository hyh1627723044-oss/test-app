.hero {
  min-height: 238rpx;
  padding: 34rpx 30rpx;
  box-sizing: border-box;
}

.hero-copy {
  width: 100%;
  display: flex;
  flex-direction: column;
}

.eyebrow {
  font-size: 24rpx;
  color: #9a5d2f;
  margin-bottom: 14rpx;
}

.hero-title {
  font-size: 44rpx;
  line-height: 54rpx;
  color: #3b2718;
  font-weight: 600;
}

.hero-desc {
  margin-top: 18rpx;
  font-size: 26rpx;
  line-height: 36rpx;
  color: #72543d;
}

.search-card {
  margin-top: 22rpx;
  padding: 18rpx 18rpx 10rpx;
  box-sizing: border-box;
}

.search-top {
  display: flex;
  flex-direction: row;
  align-items: center;
}

.search-box {
  flex: 1;
  height: 74rpx;
  padding: 0 18rpx;
  box-sizing: border-box;
  border-radius: 20rpx;
  background-color: #f8e8cf;
  border: 1px solid #d9b98d;
  display: flex;
  flex-direction: row;
  align-items: center;
}

.search-mascot {
  width: 148rpx;
  height: 90rpx;
  margin-left: 14rpx;
  flex-shrink: 0;
}

.search-input {
  flex: 1;
  height: 74rpx;
  font-size: 28rpx;
  color: #3b2718;
}

.search-clear {
  padding: 8rpx 14rpx;
  border-radius: 14rpx;
  background-color: #efd2aa;
}

.search-clear-text {
  font-size: 24rpx;
  color: #9a5d2f;
}

.quick-filter-bar {
  margin-top: 16rpx;
  display: flex;
  flex-direction: row;
  align-items: flex-start;
}

.quick-tag-scroll {
  flex: 1;
  white-space: nowrap;
}

.quick-tag-row {
  display: inline-flex;
  flex-direction: row;
  align-items: center;
  white-space: nowrap;
}

.quick-tag {
  height: 54rpx;
  margin: 0 12rpx 12rpx 0;
  padding: 0 24rpx;
  border-radius: 18rpx;
  background-color: #fff0da;
  border: 2rpx solid #cfa46f;
  box-sizing: border-box;
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
}

.quick-tag-more {
  width: 64rpx;
  padding: 0;
  border-style: dashed;
  background-color: #fff9e8;
}

.quick-tag-active {
  background-color: #4b321f;
}

.quick-tag-text {
  font-size: 24rpx;
  color: #a76225;
}

.quick-tag-active .quick-tag-text {
  color: #fff6df;
}

.add-recipe-mini {
  width: 136rpx;
  height: 54rpx;
  margin-left: 12rpx;
  border-radius: 18rpx;
  background-color: #ee8e36;
  border: 4rpx solid #4b321f;
  box-sizing: border-box;
  box-shadow: 4rpx 4rpx 0 #d7b88f;
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.add-recipe-mini-text {
  font-size: 24rpx;
  color: #fff6df;
  font-weight: 600;
}

.category-strip {
  white-space: nowrap;
  margin: 26rpx 0;
}

.category-pill {
  display: inline-flex;
  height: 58rpx;
  padding: 0 28rpx;
  margin-right: 16rpx;
  border-radius: 24rpx;
  border: 1px solid #d8b98f;
  background-color: #fff9e8;
  align-items: center;
}

.category-pill-active {
  background-color: #4b321f;
  border-color: #4b321f;
}

.category-text {
  font-size: 26rpx;
  color: #70533d;
}

.category-pill-active .category-text {
  color: #fff6df;
}

.recipe-list {
  display: flex;
  flex-direction: column;
}

.empty-state {
  padding: 42rpx 28rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.empty-image {
  width: 190rpx;
  height: 190rpx;
}

.empty-title {
  margin-top: 10rpx;
  font-size: 32rpx;
  color: #3b2718;
  font-weight: 600;
}

.empty-desc {
  margin-top: 12rpx;
  font-size: 25rpx;
  line-height: 36rpx;
  color: #72543d;
  text-align: center;
}

.recipe-card {
  position: relative;
  min-height: 450rpx;
  padding: 18rpx 18rpx 20rpx;
  margin-bottom: 28rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
}

.card-tape {
  position: absolute;
  left: 38rpx;
  top: -25rpx;
  width: 150rpx;
  height: 66rpx;
  transform: rotate(-4deg);
  z-index: 2;
}

.card-decor {
  position: absolute;
  right: 24rpx;
  top: 22rpx;
  width: 82rpx;
  height: 82rpx;
  z-index: 3;
}

.recipe-cover {
  position: relative;
  width: 100%;
  height: 260rpx;
  border-radius: 24rpx;
  overflow: hidden;
  background-color: #f0c993;
  border: 1px solid #d7b17e;
}

.recipe-cover-image {
  width: 100%;
  height: 260rpx;
}

.recipe-cover-empty {
  position: relative;
  width: 100%;
  height: 260rpx;
  display: flex;
  justify-content: center;
  align-items: center;
}

.recipe-letter-card {
  position: absolute;
  left: 50%;
  top: 50%;
  width: 190rpx;
  height: 190rpx;
  margin-left: -95rpx;
  margin-top: -95rpx;
  border-radius: 95rpx;
  background-color: #fff6df;
  border: 5rpx solid #4b321f;
  box-shadow: 8rpx 8rpx 0 rgba(196, 105, 31, 0.28);
  display: flex;
  align-items: center;
  justify-content: center;
}

.recipe-cover-letter {
  font-size: 82rpx;
  line-height: 96rpx;
  color: #a75d23;
  font-weight: 600;
}

.letter-spark {
  position: absolute;
  width: 18rpx;
  height: 18rpx;
  border-radius: 6rpx;
  background-color: #ee8e36;
  border: 4rpx solid #4b321f;
  transform: rotate(28deg);
}

.letter-spark-left {
  left: -20rpx;
  top: 28rpx;
}

.letter-spark-right {
  right: -10rpx;
  top: 48rpx;
}

.letter-leaf {
  position: absolute;
  width: 34rpx;
  height: 20rpx;
  background-color: #d8dfa5;
  border: 4rpx solid #4b321f;
  border-radius: 28rpx 4rpx 28rpx 4rpx;
}

.letter-leaf-left {
  left: 28rpx;
  bottom: 24rpx;
  transform: rotate(18deg);
}

.letter-leaf-right {
  right: 28rpx;
  bottom: 24rpx;
  transform: rotate(-18deg) scaleX(-1);
}

.time-badge {
  position: absolute;
  right: 18rpx;
  top: 18rpx;
  padding: 8rpx 16rpx;
  border-radius: 18rpx;
  background-color: #fff6df;
  border: 3rpx solid #4b321f;
}

.time-badge-text {
  font-size: 23rpx;
  color: #9a5d2f;
  font-weight: 600;
}

.recipe-info {
  padding: 20rpx 4rpx 0;
  display: flex;
  flex-direction: column;
}

.recipe-title-row {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
}

.recipe-title {
  flex: 1;
  font-size: 36rpx;
  color: #3b2718;
  font-weight: 600;
}

.recipe-desc {
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 34rpx;
  color: #72543d;
}

.recipe-meal {
  margin-left: 16rpx;
  padding: 6rpx 14rpx;
  border-radius: 16rpx;
  background-color: #d8dfa5;
  font-size: 22rpx;
  color: #68753f;
  flex-shrink: 0;
}

.recipe-tag-row {
  margin-top: 12rpx;
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
}

.recipe-tag {
  margin: 0 10rpx 8rpx 0;
  padding: 6rpx 12rpx;
  border-radius: 14rpx;
  background-color: #ffe2b5;
  font-size: 22rpx;
  color: #a76225;
}

.recipe-action-row {
  margin-top: 14rpx;
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
}

.recipe-note {
  font-size: 23rpx;
  color: #95745a;
}

.plan-btn {
  min-width: 146rpx;
  height: 56rpx;
  padding: 0 18rpx;
  box-sizing: border-box;
  border-radius: 20rpx;
  background-color: #ee8e36;
  border: 4rpx solid #4b321f;
  display: flex;
  align-items: center;
  justify-content: center;
}

.plan-btn-text {
  font-size: 24rpx;
  color: #fff6df;
  font-weight: 600;
}
