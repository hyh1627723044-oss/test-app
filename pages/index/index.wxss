.hero {
  min-height: 238rpx;
  padding: 34rpx 30rpx;
  box-sizing: border-box;
}

.hero-copy {
  width: 100%;
  display: flex;
  flex-direction: column;
}

.eyebrow {
  font-size: 24rpx;
  color: #8a5a34;
  margin-bottom: 14rpx;
}

.hero-title {
  font-size: 44rpx;
  line-height: 54rpx;
  color: #271b12;
  font-weight: 600;
}

.hero-desc {
  margin-top: 18rpx;
  font-size: 26rpx;
  line-height: 36rpx;
  color: #755f4d;
}

.search-card {
  margin-top: 22rpx;
  padding: 18rpx 18rpx 10rpx;
  box-sizing: border-box;
}

.search-top {
  display: flex;
  flex-direction: row;
  align-items: center;
}

.search-box {
  flex: 1;
  height: 74rpx;
  padding: 0 18rpx;
  box-sizing: border-box;
  border-radius: 20rpx;
  background-color: #f8f3ee;
  border: 1px solid #ecd9c8;
  display: flex;
  flex-direction: row;
  align-items: center;
}

.search-mascot {
  width: 148rpx;
  height: 90rpx;
  margin-left: 14rpx;
  flex-shrink: 0;
}

.search-input {
  flex: 1;
  height: 74rpx;
  font-size: 28rpx;
  color: #251b14;
}

.search-clear {
  padding: 8rpx 14rpx;
  border-radius: 14rpx;
  background-color: #eee0d7;
}

.search-clear-text {
  font-size: 24rpx;
  color: #8a5a34;
}

.quick-filter-bar {
  margin-top: 16rpx;
  display: flex;
  flex-direction: row;
  align-items: flex-start;
}

.quick-tag-scroll {
  flex: 1;
  white-space: nowrap;
}

.quick-tag-row {
  display: inline-flex;
  flex-direction: row;
  align-items: center;
  white-space: nowrap;
}

.quick-tag {
  height: 54rpx;
  margin: 0 12rpx 12rpx 0;
  padding: 0 24rpx;
  border-radius: 18rpx;
  background-color: #fff6ec;
  border: 2rpx solid #e1c6a9;
  box-sizing: border-box;
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
}

.quick-tag-more {
  width: 64rpx;
  padding: 0;
  border-style: dashed;
  background-color: #fffaf1;
}

.quick-tag-active {
  background-color: #2b2119;
}

.quick-tag-text {
  font-size: 24rpx;
  color: #a2672a;
}

.quick-tag-active .quick-tag-text {
  color: #fff8ef;
}

.add-recipe-mini {
  width: 136rpx;
  height: 54rpx;
  margin-left: 12rpx;
  border-radius: 18rpx;
  background-color: #c87420;
  border: 4rpx solid #2b2119;
  box-sizing: border-box;
  box-shadow: 4rpx 4rpx 0 #ead8c8;
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.add-recipe-mini-text {
  font-size: 24rpx;
  color: #fff8ef;
  font-weight: 600;
}

.category-strip {
  white-space: nowrap;
  margin: 26rpx 0;
}

.category-pill {
  display: inline-flex;
  height: 58rpx;
  padding: 0 28rpx;
  margin-right: 16rpx;
  border-radius: 24rpx;
  border: 1px solid #e2d6cb;
  background-color: #ffffff;
  align-items: center;
}

.category-pill-active {
  background-color: #2b2119;
  border-color: #2b2119;
}

.category-text {
  font-size: 26rpx;
  color: #6f6258;
}

.category-pill-active .category-text {
  color: #fff8ef;
}

.recipe-list {
  display: flex;
  flex-direction: column;
}

.empty-state {
  padding: 42rpx 28rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.empty-image {
  width: 190rpx;
  height: 190rpx;
}

.empty-title {
  margin-top: 10rpx;
  font-size: 32rpx;
  color: #251b14;
  font-weight: 600;
}

.empty-desc {
  margin-top: 12rpx;
  font-size: 25rpx;
  line-height: 36rpx;
  color: #756a60;
  text-align: center;
}

.recipe-card {
  position: relative;
  min-height: 450rpx;
  padding: 18rpx 18rpx 20rpx;
  margin-bottom: 28rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
}

.card-tape {
  position: absolute;
  left: 38rpx;
  top: -25rpx;
  width: 150rpx;
  height: 66rpx;
  transform: rotate(-4deg);
  z-index: 2;
}

.card-decor {
  position: absolute;
  right: 28rpx;
  top: 26rpx;
  width: 74rpx;
  height: 86rpx;
  z-index: 3;
}

.decor-petal,
.decor-center,
.decor-leaf,
.decor-star-core {
  display: none;
  position: absolute;
}

.card-decor-flower .decor-petal {
  display: block;
  width: 24rpx;
  height: 26rpx;
  border-radius: 22rpx 22rpx 8rpx 22rpx;
  background-color: #f28b63;
  border: 4rpx solid #2b2119;
}

.card-decor-flower .decor-petal-one {
  left: 24rpx;
  top: 0;
  transform: rotate(-18deg);
}

.card-decor-flower .decor-petal-two {
  left: 42rpx;
  top: 18rpx;
  transform: rotate(64deg);
}

.card-decor-flower .decor-petal-three {
  left: 20rpx;
  top: 34rpx;
  transform: rotate(156deg);
}

.card-decor-flower .decor-petal-four {
  left: 2rpx;
  top: 16rpx;
  transform: rotate(244deg);
}

.card-decor-flower .decor-center {
  display: block;
  left: 28rpx;
  top: 22rpx;
  width: 18rpx;
  height: 18rpx;
  border-radius: 9rpx;
  background-color: #f7c85f;
  border: 4rpx solid #2b2119;
}

.card-decor-flower::after {
  content: '';
  position: absolute;
  left: 34rpx;
  top: 46rpx;
  width: 5rpx;
  height: 40rpx;
  border-radius: 5rpx;
  background-color: #526343;
  transform: rotate(10deg);
}

.card-decor-flower .decor-leaf-one {
  display: block;
  left: 38rpx;
  top: 60rpx;
  width: 28rpx;
  height: 16rpx;
  border-radius: 20rpx 4rpx 20rpx 4rpx;
  background-color: #dfe9d7;
  border: 3rpx solid #2b2119;
  transform: rotate(-18deg);
}

.card-decor-leaf .decor-leaf {
  display: block;
  width: 42rpx;
  height: 24rpx;
  border-radius: 32rpx 6rpx 32rpx 6rpx;
  background-color: #dfe9d7;
  border: 4rpx solid #2b2119;
}

.card-decor-leaf .decor-leaf-one {
  left: 2rpx;
  top: 22rpx;
  transform: rotate(-42deg);
}

.card-decor-leaf .decor-leaf-two {
  left: 28rpx;
  top: 16rpx;
  transform: rotate(42deg) scaleX(-1);
}

.card-decor-leaf::after {
  content: '';
  position: absolute;
  left: 36rpx;
  top: 30rpx;
  width: 5rpx;
  height: 52rpx;
  border-radius: 5rpx;
  background-color: #526343;
  transform: rotate(18deg);
}

.card-decor-star .decor-star-core {
  display: block;
  left: 16rpx;
  top: 12rpx;
  width: 42rpx;
  height: 42rpx;
  border-radius: 12rpx;
  background-color: #f7c85f;
  border: 4rpx solid #2b2119;
  transform: rotate(28deg);
}

.card-decor-star .decor-star-core::after {
  content: '';
  position: absolute;
  left: -4rpx;
  top: -4rpx;
  width: 42rpx;
  height: 42rpx;
  border-radius: 12rpx;
  background-color: #f7c85f;
  border: 4rpx solid #2b2119;
  transform: rotate(32deg);
  z-index: -1;
}

.card-decor-star::after {
  content: '';
  position: absolute;
  right: 4rpx;
  bottom: 8rpx;
  width: 12rpx;
  height: 12rpx;
  border-radius: 4rpx;
  background-color: #f28b63;
  border: 3rpx solid #2b2119;
  transform: rotate(18deg);
}

.recipe-cover {
  position: relative;
  width: 100%;
  height: 260rpx;
  border-radius: 24rpx;
  overflow: hidden;
  background-color: #f3dcc6;
  border: 1px solid #ead2bd;
}

.recipe-cover-image {
  width: 100%;
  height: 260rpx;
}

.recipe-cover-empty {
  position: relative;
  width: 100%;
  height: 260rpx;
  display: flex;
  justify-content: center;
  align-items: center;
}

.recipe-letter-card {
  position: absolute;
  left: 50%;
  top: 50%;
  width: 190rpx;
  height: 190rpx;
  margin-left: -95rpx;
  margin-top: -95rpx;
  border-radius: 95rpx;
  background-color: #fff8ef;
  border: 5rpx solid #2b2119;
  box-shadow: 8rpx 8rpx 0 rgba(200, 116, 32, 0.22);
  display: flex;
  align-items: center;
  justify-content: center;
}

.recipe-cover-letter {
  font-size: 82rpx;
  line-height: 96rpx;
  color: #9d5d24;
  font-weight: 600;
}

.letter-spark {
  position: absolute;
  width: 18rpx;
  height: 18rpx;
  border-radius: 6rpx;
  background-color: #c87420;
  border: 4rpx solid #2b2119;
  transform: rotate(28deg);
}

.letter-spark-left {
  left: -20rpx;
  top: 28rpx;
}

.letter-spark-right {
  right: -10rpx;
  top: 48rpx;
}

.letter-leaf {
  position: absolute;
  width: 34rpx;
  height: 20rpx;
  background-color: #dfe9d7;
  border: 4rpx solid #2b2119;
  border-radius: 28rpx 4rpx 28rpx 4rpx;
}

.letter-leaf-left {
  left: 28rpx;
  bottom: 24rpx;
  transform: rotate(18deg);
}

.letter-leaf-right {
  right: 28rpx;
  bottom: 24rpx;
  transform: rotate(-18deg) scaleX(-1);
}

.time-badge {
  position: absolute;
  right: 18rpx;
  top: 18rpx;
  padding: 8rpx 16rpx;
  border-radius: 18rpx;
  background-color: #fff8ef;
  border: 3rpx solid #2b2119;
}

.time-badge-text {
  font-size: 23rpx;
  color: #8a5a34;
  font-weight: 600;
}

.recipe-info {
  padding: 20rpx 4rpx 0;
  display: flex;
  flex-direction: column;
}

.recipe-title-row {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
}

.recipe-title {
  flex: 1;
  font-size: 36rpx;
  color: #251b14;
  font-weight: 600;
}

.recipe-desc {
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 34rpx;
  color: #756a60;
}

.recipe-meal {
  margin-left: 16rpx;
  padding: 6rpx 14rpx;
  border-radius: 16rpx;
  background-color: #dfe9d7;
  font-size: 22rpx;
  color: #526343;
  flex-shrink: 0;
}

.recipe-tag-row {
  margin-top: 12rpx;
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
}

.recipe-tag {
  margin: 0 10rpx 8rpx 0;
  padding: 6rpx 12rpx;
  border-radius: 14rpx;
  background-color: #fff1dd;
  font-size: 22rpx;
  color: #a2672a;
}

.recipe-action-row {
  margin-top: 14rpx;
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
}

.recipe-note {
  font-size: 23rpx;
  color: #9a8b7d;
}

.plan-btn {
  min-width: 146rpx;
  height: 56rpx;
  padding: 0 18rpx;
  box-sizing: border-box;
  border-radius: 20rpx;
  background-color: #c87420;
  border: 4rpx solid #2b2119;
  display: flex;
  align-items: center;
  justify-content: center;
}

.plan-btn-text {
  font-size: 24rpx;
  color: #fff8ef;
  font-weight: 600;
}
