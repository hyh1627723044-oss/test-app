page {
  min-height: 100vh;
  color: #3b2718;
  background-color: #f8e6bd;
  background-image: linear-gradient(180deg, #f9edcf 0%, #f5dfb4 48%, #fff6df 100%);
}

.page-shell {
  min-height: 100vh;
  padding: 28rpx 28rpx 210rpx;
  box-sizing: border-box;
}

.paper-card {
  box-sizing: border-box;
  background-color: #fff9e8;
  border: 3rpx solid #6f5137;
  border-radius: 30rpx;
  box-shadow: 7rpx 8rpx 0 rgba(112, 70, 38, 0.22);
}

.paper-hero {
  background-color: #f8dfb4;
  border-color: #6f5137;
}

.paper-dashed-card {
  box-sizing: border-box;
  background-color: rgba(255, 246, 223, 0.94);
  border: 2rpx dashed #c89d68;
  border-radius: 28rpx;
}

.doodle-tape {
  position: absolute;
  border-radius: 10rpx;
  background-color: rgba(218, 174, 114, 0.66);
}

.doodle-underline {
  height: 7rpx;
  border-radius: 8rpx;
  background-color: #e8792c;
  transform: rotate(-2deg);
}

.bottom-nav {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  height: 188rpx;
  padding: 14rpx 42rpx 22rpx;
  box-sizing: border-box;
  background-color: #fff6df;
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: flex-end;
}

.bottom-nav::before {
  content: '';
  position: absolute;
  left: 0;
  right: 0;
  top: -2rpx;
  height: 2rpx;
  background-color: #ead5b6;
  box-shadow: 0 -8rpx 18rpx rgba(112, 70, 38, 0.08);
}

.nav-item {
  width: 160rpx;
  height: 150rpx;
  border-radius: 34rpx;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  align-items: center;
  opacity: 0.58;
}

.nav-item-active {
  opacity: 1;
  background-color: #f6bd67;
}

.nav-icon {
  width: 108rpx;
  height: 92rpx;
}

.nav-label {
  margin-top: 4rpx;
  font-size: 34rpx;
  line-height: 40rpx;
  color: #6f5137;
  font-weight: 500;
}
