APP_ENV=development
HTTP_ADDR=:8080

# Use docker.io/library outside mainland China if preferred.
DOCKER_IMAGE_PREFIX=m.daocloud.io/docker.io/library
GOPROXY=https://goproxy.cn,direct

# Docker Compose ports and local PostgreSQL credentials
API_PORT=8080
POSTGRES_PORT=5432
POSTGRES_DB=recipe_planner
POSTGRES_USER=recipe
POSTGRES_PASSWORD=recipe

# Used when running the Go API directly outside Docker
DATABASE_URL=postgres://recipe:recipe@localhost:5432/recipe_planner?sslmode=disable
JWT_SECRET=change-me-in-production

# Optional: AI endpoints return an unavailable error when the key is empty
TENCENT_MAAS_API_KEY=
TENCENT_MAAS_BASE_URL=https://tokenhub.tencentmaas.com/v1
TENCENT_MAAS_TEXT_MODEL=hy3
TENCENT_MAAS_VISION_MODEL=hy-vision-2.0-instruct
